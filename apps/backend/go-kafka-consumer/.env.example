# NOTE: unlike the Python services, this Go service does NOT auto-load a
# .env file (no godotenv dependency) — these must be real environment
# variables in whatever shell/container runs it. Locally:
#
#   set -a; source .env; set +a; go run .        (bash/zsh)
#   Get-Content .env | ForEach-Object { ... }     (PowerShell — or just
#                                                   set them manually)
#
# Or pass them via `docker run --env-file .env ...` / your ECS task
# definition / Kubernetes ConfigMap when deployed.
#
# All values below are the built-in defaults (internal/config/config.go)
# — copy this file to .env and only override what you need to change.

KAFKA_BROKER=localhost:9092
KAFKA_GROUP_ID=travelmaster-go-consumer

FLIGHT_TOPIC=travelguru.agents.flights
HOTEL_TOPIC=travelguru.agents.hotels
PLACES_TOPIC=travelguru.agents.places
WEATHER_TOPIC=travelguru.agents.weather

HTTP_PORT=8081
METRICS_PORT=2112
PPROF_PORT=6060
